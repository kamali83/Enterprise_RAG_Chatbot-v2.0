# Application Settings
APP_NAME=Enterprise RAG Chatbot
APP_VERSION=2.1.0
DEBUG=True

# Database (SQLite for local testing)
DATABASE_URL=sqlite:///./rag_chatbot.db
DATABASE_ASYNC_URL=sqlite+aiosqlite:///./rag_chatbot.db

# Redis (disabled for local testing)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=supersecretkey123
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Configuration
LLM_PROVIDER=local
MODEL_NAME=google/flan-t5-large
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OLLAMA_MODEL=llama2
OLLAMA_BASE_URL=http://localhost:11434

# vLLM Configuration (high-performance local inference)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Groq Configuration (ultra-fast cloud inference)
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# Together AI Configuration
TOGETHER_API_KEY=
TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVAL_K=5
USE_RERANKING=False
RERANK_MODEL=BAAI/bge-reranker-large

# Hybrid Search Configuration
USE_HYBRID_SEARCH=True
HYBRID_DENSE_WEIGHT=0.5
HYBRID_SPARSE_WEIGHT=0.5
BM25_ENABLED=True

# Cache Configuration
CACHE_TTL=3600
USE_SEMANTIC_CACHE=False
SEMANTIC_CACHE_THRESHOLD=0.85

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=.txt,.pdf,.docx,.md
DOCS_DIR=data/docs

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Monitoring
PROMETHEUS_ENABLED=False
OTEL_ENABLED=False
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# Query Understanding
USE_QUERY_CLASSIFICATION=True
USE_QUERY_REWRITING=True
USE_MULTI_QUERY=False
USE_HYDE=False

# Feedback & Analytics
FEEDBACK_ENABLED=True
ANALYTICS_ENABLED=True

# WebSocket
WEBSOCKET_ENABLED=True
WEBSOCKET_HEARTBEAT_INTERVAL=30
